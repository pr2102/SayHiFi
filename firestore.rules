rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isChatMember(chatId) {
      return signedIn()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
    }

    function isNewChatMember() {
      return signedIn()
        && request.resource.data.members is list
        && request.resource.data.members.size() >= 1
        && request.resource.data.members.size() <= 2
        && request.auth.uid in request.resource.data.members;
    }

    match /users/{uid} {
      allow get: if signedIn();
      allow list: if signedIn();
      allow create, update: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow get, list: if signedIn()
        && request.auth.uid in resource.data.members;
      allow create: if isNewChatMember();
      allow update: if signedIn()
        && request.auth.uid in resource.data.members
        && request.resource.data.members == resource.data.members;
      allow delete: if false;

      match /messages/{messageId} {
        allow get, list: if isChatMember(chatId);
        allow create: if isChatMember(chatId)
          && request.resource.data.senderId == request.auth.uid;
        allow update: if isChatMember(chatId);
        allow delete: if false;
      }
    }

    match /calls/{callId} {
      allow get, list: if signedIn()
        && (resource.data.callerId == request.auth.uid
          || resource.data.receiverId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.callerId == request.auth.uid
        && request.resource.data.receiverId is string
        && request.resource.data.chatId is string;
      allow update: if signedIn()
        && (resource.data.callerId == request.auth.uid
          || resource.data.receiverId == request.auth.uid);
      allow delete: if false;

      match /offerCandidates/{candidateId} {
        allow get, list, create: if signedIn()
          && exists(/databases/$(database)/documents/calls/$(callId))
          && (get(/databases/$(database)/documents/calls/$(callId)).data.callerId == request.auth.uid
            || get(/databases/$(database)/documents/calls/$(callId)).data.receiverId == request.auth.uid);
        allow update, delete: if false;
      }

      match /answerCandidates/{candidateId} {
        allow get, list, create: if signedIn()
          && exists(/databases/$(database)/documents/calls/$(callId))
          && (get(/databases/$(database)/documents/calls/$(callId)).data.callerId == request.auth.uid
            || get(/databases/$(database)/documents/calls/$(callId)).data.receiverId == request.auth.uid);
        allow update, delete: if false;
      }
    }
  }
}
